        }

        .cart-actions {
            display: flex;
            gap: 1rem;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .cart-actions button, .cart-actions a {
            padding: 1rem 2rem;
            border-radius: 6px;
            font-size: 1.1rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
            border: none;
        }

        .continue-shopping {
            background: #6c757d;
            color: white;
        }

        .continue-shopping:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

        .checkout-btn {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            flex: 1;
            min-width: 200px;
        }

        .checkout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(40,167,69,0.4);
        }

        .clear-cart-btn {
            background: #dc3545;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 1rem;
            width: 100%;
        }

        .clear-cart-btn:hover {
            background: #c82333;
            transform: translateY(-2px);
        }

        @media (max-width: 768px) {
            .cart-content {
                flex-direction: column;
            }

            .cart-summary {
                width: 100%;
                position: static;
            }

            .cart-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .cart-item img {
                margin-right: 0;
            }

            .cart-item-price {
                margin-right: 0;
                align-self: flex-end;
            }

            .cart-item-quantity {
                margin-right: 0;
                align-self: center;
            }

            .cart-actions {
                flex-direction: column;
            }

            .cart-actions button, .cart-actions a {
                width: 100%;
            }
        }

        /* Dark mode styles */
        body.dark-mode {
            background-color: #121212;
            color: #e0e0e0;
        }

