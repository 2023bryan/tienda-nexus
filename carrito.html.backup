    <link rel="stylesheet" href="header.css">
    <link rel="stylesheet" href="chat.css">
</head>
<body>
    <div id="site-header"></div>

    <div class="cart-container">
        <div class="cart-header">
            <h1>🛒 Carrito de Compras</h1>
        </div>

        <div id="cart-content">
            <!-- Cart items will be loaded here -->
        </div>
    </div>

    <!-- Chat Bubble -->
    <button class="chat-bubble" id="chatBubble" onclick="openChat()">💬</button>

    <!-- Chat Panel -->
    <div class="chat-panel hidden" id="chatPanel">
        <div class="chat-header">
            <h3>Tienda Nexus</h3>
            <button class="chat-close" onclick="closeChat()">✕</button>
        </div>
        <div class="chat-messages" id="chatMessages">
            <div class="chat-message bot">
                <strong>Hola, buenos tardes. 👋</strong><br>
                Gracias por su comunicación a Tienda Nexus, mi nombre es Byron. 😊<br><br>
                ¿Con quién tenemos el gusto?
            </div>
        </div>
        <div class="chat-input-area">
            <div class="chat-actions">
                <button onclick="attachImage()" title="Enviar imagen">🖼️</button>
                <button onclick="recordAudio()" title="Enviar audio">🎙️</button>
            </div>
            <textarea class="chat-input" id="chatInput" placeholder="Escribe tu mensaje..." rows="1"></textarea>
            <button class="chat-send" onclick="sendMessage()">➤</button>
        </div>
    </div>

    <footer>
        <p>&copy; 2026 Tienda Nexus. Todos los derechos reservados.</p>
    </footer>

    <script src="chat.js"></script>
    <script src="header.js"></script>
    <script>
        // Product data for images and categories
        const products = [
            { id: 1, name: 'Refrigerador Doble Puerta', price: 4500, image: 'https://via.placeholder.com/400x300?text=Refrigerador', category: 'Refrigeración' },
            { id: 2, name: 'Lavadora Automática 8kg', price: 3200, image: 'https://via.placeholder.com/400x300?text=Lavadora', category: 'Lavado' },
            { id: 3, name: 'Microondas Digital', price: 850, image: 'https://via.placeholder.com/400x300?text=Microondas', category: 'Cocina' },
            { id: 4, name: 'Aspiradora Robot', price: 1800, image: 'https://via.placeholder.com/400x300?text=Aspiradora+Robot', category: 'Seguridad' },
            { id: 5, name: 'Cafetera Espresso', price: 650, image: 'https://via.placeholder.com/400x300?text=Cafetera', category: 'Cocina' },
            { id: 6, name: 'Televisor LED 55"', price: 2800, image: 'https://via.placeholder.com/400x300?text=Televisor', category: 'Entretenimiento' },
            { id: 7, name: 'Sistema de Sonido HiFi con Tubos de Vacío', price: 2350, image: 'https://via.placeholder.com/400x300?text=Sistema+Sonido', category: 'Entretenimiento' },
            { id: 8, name: 'Selladora al Vacío Automática 2 en 1', price: 430, image: 'https://via.placeholder.com/400x300?text=Selladora+Vacuo', category: 'Cocina' },
            { id: 9, name: 'Grifo de Cocina con Mango Único', price: 255, image: 'https://via.placeholder.com/400x300?text=Grifo+Cocina', category: 'Cocina' }
        ];

        function loadCart() {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const cartContent = document.getElementById('cart-content');

            if (cart.length === 0) {
                cartContent.innerHTML = `
                    <div class="cart-empty">
                        <h2>Tu carrito está vacío</h2>
                        <p>¡Agrega algunos productos para comenzar tu compra!</p>
                        <a href="tienda.html" class="shop-btn">Ir a la tienda</a>
                    </div>
                `;
                return;
            }

            let cartHTML = `
                <div class="cart-content">
                    <div class="cart-items-section">
                        <div class="cart-items-header">
                            Productos en tu carrito (${cart.length})
                        </div>
                        <div class="cart-items">
            `;

            let total = 0;

            cart.forEach(item => {
                const product = products.find(p => p.id === item.id);
                if (product) {
                    const itemTotal = product.price * item.quantity;
                    total += itemTotal;

                    cartHTML += `
                        <div class="cart-item">
                            <img src="${product.image}" alt="${product.name}">
                            <div class="cart-item-details">
                                <h3>${product.name}</h3>
                                <p>Categoría: ${product.category}</p>
                            </div>
                            <div class="cart-item-price">Q${product.price.toLocaleString()}</div>
                            <div class="cart-item-quantity">
                                <button class="quantity-btn" onclick="decreaseQuantity(${item.id})">−</button>
                                <span class="quantity-display">${item.quantity}</span>
                                <button class="quantity-btn" onclick="increaseQuantity(${item.id})">+</button>
                            </div>
                            <button class="cart-item-remove" onclick="removeItem(${item.id})">Eliminar</button>
                        </div>
                    `;
                }
            });

            cartHTML += `
                        </div>
                    </div>
                    <div class="cart-summary">
                        <h2>Resumen del Pedido</h2>
                        <button class="clear-cart-btn" onclick="clearCart()">🗑️ Limpiar Carrito</button>
                        <div class="summary-row">
                            <span>Subtotal (${cart.length} ${cart.length === 1 ? 'producto' : 'productos'}):</span>
                            <span>Q${total.toLocaleString()}</span>
                        </div>
                        <div class="summary-row">
                            <span>Envío:</span>
                            <span>Gratis</span>
                        </div>
                        <div class="summary-row summary-total">
                            <span>Total:</span>
                            <span>Q${total.toLocaleString()}</span>
                        </div>
                        <div class="cart-actions">
                            <a href="tienda.html" class="continue-shopping">Continuar Comprando</a>
                            <button class="checkout-btn" onclick="checkout()">Finalizar Compra</button>
                        </div>
                    </div>
                </div>
            `;

            cartContent.innerHTML = cartHTML;
            updateCartCount();
        }

        function increaseQuantity(productId) {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const item = cart.find(i => i.id === productId);
            if (item) {
                item.quantity++;
                localStorage.setItem('cart', JSON.stringify(cart));
                loadCart();
            }
        }

        function decreaseQuantity(productId) {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const item = cart.find(i => i.id === productId);
            if (item && item.quantity > 1) {
                item.quantity--;
                localStorage.setItem('cart', JSON.stringify(cart));
                loadCart();
            } else if (item && item.quantity === 1) {
                removeItem(productId);
            }
        }

        function removeItem(productId) {
            if (confirm('¿Estás seguro de que quieres eliminar este producto del carrito?')) {
                let cart = JSON.parse(localStorage.getItem('cart')) || [];
                cart = cart.filter(item => item.id !== productId);
                localStorage.setItem('cart', JSON.stringify(cart));
                loadCart();
            }
        }

        function clearCart() {
            if (confirm('¿Estás seguro de que quieres vaciar todo el carrito? Esta acción no se puede deshacer.')) {
                localStorage.removeItem('cart');
                loadCart();
            }
        }

        function checkout() {
            alert('¡Gracias por tu compra! Esta es una demostración. En un sitio real, aquí procesarías el pago.');
            // Clear cart after checkout
            localStorage.removeItem('cart');
            loadCart();
        }

        // Load cart when page loads
        document.addEventListener('DOMContentLoaded', function() {
            loadCart();
        });

        // Also try to load cart immediately in case DOMContentLoaded already fired
        if (document.readyState === 'loading') {
            // Document still loading, wait for DOMContentLoaded
        } else {
            // DOM already loaded, load cart immediately
            loadCart();
        }
    </script>
</body>
</html>